# ======================================
# Application
# ======================================
NODE_ENV=development
PORT=5000

# ======================================
# PostgreSQL
# ======================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=your_database_user
PG_PASSWORD=your_database_password

# Prisma Connection URL
DATABASE_URL="postgresql://your_database_user:your_database_password@localhost:5432/your_database_name?schema=public"

# ======================================
# Redis
# ======================================
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ======================================
# RabbitMQ
# ======================================
RABBITMQ_URL=amqp://your_rabbitmq_user:your_rabbitmq_password@localhost:5672/your_vhost
RABBITMQ_QUEUE=api_hits

# ======================================
# Authentication
# ======================================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=24h

# ======================================
# API Keys
# ======================================
VALID_API_KEYS=your_api_key_1,your_api_key_2

# ======================================
# Rate Limiting
# ======================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100